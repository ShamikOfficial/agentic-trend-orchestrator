# Public API base (must include /api/v1). Used at build time for NEXT_PUBLIC_*.
#
# Vercel: Project Settings → Environment Variables
# - Set the same key for Production and Preview with different values if you use
#   separate staging vs production APIs.
# - Preview builds need a backend that allows the preview origin (see CORS in backend).
NEXT_PUBLIC_API_BASE_URL=https://your-api.example.com/api/v1
