# Copy this file to .env and edit values as needed.
# Current standalone Team + Workflow modules do not require external keys.

APP_ENV=development
LOG_LEVEL=info

# CORS: comma-separated browser origins allowed to call the API (in addition to localhost).
# Add your production frontend origin, e.g. https://my-app.vercel.app
# CORS_ORIGINS=https://my-app.vercel.app,https://www.example.com

# Allow https://*.vercel.app Origins (Vercel Preview + default *.vercel.app URLs).
# Default is on; set to false to disable (e.g. lock API to listed origins only).
# CORS_ALLOW_VERCEL=false

# Optional explicit regex instead of the built-in Vercel pattern (validated at startup).
# CORS_ORIGIN_REGEX=

# LLM (Google AI / Gemini API) — shared by Team Assistant, Chat Ask AI (@chat), and gemini_test.ipynb.
# GEMINI_API_KEY=

# Primary model id for backend (optional). If unset, GEMMA_TEST_MODEL is used, then gemma-3-27b-it.
# LLM_MODEL=

# Same variable as gemini_test.ipynb — set once to keep notebook + Team + Chat aligned:
# GEMMA_TEST_MODEL=gemma-3-27b-it

# Optional comma-separated fallbacks if the primary model errors (quota, 404, etc.):
# GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemma-3-12b-it

# systemInstruction support: auto (default) merges system into user text for Gemma models;
# set true to always use API system instruction, false to always merge.
# GEMINI_USE_SYSTEM_INSTRUCTION=auto

# JSON response MIME (structured JSON output): auto skips for Gemma (API rejects it); true/false to force.
# GEMINI_USE_RESPONSE_JSON_MIME=auto

# Verbose LLM logs (merge/retry messages). Raw HTTP bodies: LLM_DEBUG_RAW=1 (default off).
# LLM_VERBOSE=1
# LLM_DEBUG_RAW=1

# Optional for future integrations:
# OPENAI_API_KEY=
